@page "/"
@implements IAsyncDisposable
@using Microsoft.AspNetCore.SignalR.Client

<PageTitle>Dashboard — MacroSutra</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Dashboard</MudText>

<MudGrid>
    <!-- Portfolio Value -->
    <MudItem xs="12" md="3">
        <MudCard>
            <MudCardContent>
                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Portfolio Value</MudText>
                <MudText Typo="Typo.h5">@totalBalance.ToString("C")</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">@activeAccountCount account(s)</MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>

    <!-- Portfolio Summary -->
    <MudItem xs="12" md="3">
        <MudCard>
            <MudCardContent>
                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Total Positions</MudText>
                <MudText Typo="Typo.h5">@positions.Count</MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>

    <MudItem xs="12" md="3">
        <MudCard>
            <MudCardContent>
                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Active Strategies</MudText>
                <MudText Typo="Typo.h5">@strategies.Count(s => s.IsActive)</MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>

    <MudItem xs="12" md="3">
        <MudCard>
            <MudCardContent>
                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Recent Trades</MudText>
                <MudText Typo="Typo.h5">@recentTrades.Count</MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>

    <!-- Engine Status -->
    <MudItem xs="12">
        <MudCard>
            <MudCardContent Class="d-flex align-center gap-4">
                <MudChip T="string" Color="@(engineRunning ? Color.Success : Color.Default)" Size="Size.Small">
                    @(engineRunning ? "Engine Running" : "Engine Stopped")
                </MudChip>
                @if (lastEvaluation.HasValue)
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        Last evaluation: @lastEvaluation.Value.ToString("MMM dd, HH:mm:ss") UTC
                    </MudText>
                }
                @if (lastUpdated.HasValue)
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        Dashboard updated: @lastUpdated.Value.ToString("HH:mm:ss") UTC
                    </MudText>
                }
            </MudCardContent>
        </MudCard>
    </MudItem>

    <!-- Active Strategies -->
    <MudItem xs="12" md="6">
        <MudCard>
            <MudCardHeader>
                <MudText Typo="Typo.h6">Active Strategies</MudText>
            </MudCardHeader>
            <MudCardContent>
                @if (strategies.Any(s => s.IsActive))
                {
                    <MudSimpleTable Dense="true" Hover="true">
                        <thead>
                            <tr><th>Name</th><th>Symbols</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var s in strategies.Where(s => s.IsActive).Take(5))
                            {
                                <tr>
                                    <td>@s.Name</td>
                                    <td>@string.Join(", ", s.Symbols)</td>
                                </tr>
                            }
                        </tbody>
                    </MudSimpleTable>
                }
                else
                {
                    <MudText Color="Color.Secondary">No active strategies.</MudText>
                }
            </MudCardContent>
        </MudCard>
    </MudItem>

    <!-- Recent Trades -->
    <MudItem xs="12" md="6">
        <MudCard>
            <MudCardHeader>
                <MudText Typo="Typo.h6">Recent Trades</MudText>
            </MudCardHeader>
            <MudCardContent>
                @if (recentTrades.Count > 0)
                {
                    <MudSimpleTable Dense="true" Hover="true">
                        <thead>
                            <tr><th>Symbol</th><th>Side</th><th>Status</th><th>Date</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var t in recentTrades.Take(5))
                            {
                                <tr>
                                    <td>@t.Symbol</td>
                                    <td>@t.Side</td>
                                    <td>@t.Status</td>
                                    <td>@t.CreatedUtc.ToString("MMM dd, HH:mm")</td>
                                </tr>
                            }
                        </tbody>
                    </MudSimpleTable>
                }
                else
                {
                    <MudText Color="Color.Secondary">No trades yet.</MudText>
                }
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>

@code {
    [CascadingParameter(Name = "AccountId")] private string AccountId { get; set; } = "";
    [Inject] private IDataProvider Data { get; set; } = default!;
    [Inject] private NavigationManager Nav { get; set; } = default!;
    [Inject] private ISnackbar Snackbar { get; set; } = default!;

    private List<BrokerageAccount> brokerageAccounts = new();
    private List<TradingStrategy> strategies = new();
    private List<Trade> recentTrades = new();
    private List<MacroSutra.Core.Models.Position> positions = new();
    private bool engineRunning;
    private DateTime? lastEvaluation;
    private DateTime? lastUpdated;
    private HubConnection? hubConnection;
    private Timer? autoRefreshTimer;

    private decimal totalBalance => brokerageAccounts
        .Where(a => a.IsActive && a.CachedBalance.HasValue)
        .Sum(a => a.CachedBalance!.Value);

    private int activeAccountCount => brokerageAccounts.Count(a => a.IsActive);

    protected override async Task OnParametersSetAsync()
    {
        if (string.IsNullOrEmpty(AccountId)) return;
        await RefreshDataAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !string.IsNullOrEmpty(AccountId))
        {
            await StartHubAsync();
            autoRefreshTimer = new Timer(async _ => await InvokeAsync(async () =>
            {
                await RefreshDataAsync();
                StateHasChanged();
            }), null, TimeSpan.FromSeconds(60), TimeSpan.FromSeconds(60));
        }
    }

    private async Task RefreshDataAsync()
    {
        try
        {
            brokerageAccounts = await Data.GetBrokerageAccountsAsync(AccountId, activeOnly: true);
            strategies = await Data.GetStrategiesAsync(AccountId);
            recentTrades = await Data.GetTradesAsync(AccountId);
            positions = await Data.GetPositionsAsync(AccountId);
            lastUpdated = DateTime.UtcNow;

            var latestEval = strategies
                .Where(s => s.LastEvaluatedUtc.HasValue)
                .Select(s => s.LastEvaluatedUtc!.Value)
                .DefaultIfEmpty()
                .Max();
            if (latestEval != default)
            {
                lastEvaluation = latestEval;
                engineRunning = (DateTime.UtcNow - latestEval).TotalMinutes < 5;
            }
        }
        catch { /* Cosmos not configured yet */ }
    }

    private async Task StartHubAsync()
    {
        try
        {
            hubConnection = new HubConnectionBuilder()
                .WithUrl(Nav.ToAbsoluteUri("/hubs/macrosutra"))
                .WithAutomaticReconnect()
                .Build();

            hubConnection.On<MacroSutra.Core.Models.StrategyAlertEvent>("StrategyTriggered", async alert =>
            {
                await InvokeAsync(async () =>
                {
                    Snackbar.Add($"{alert.StrategyName} triggered on {alert.Symbol}", Severity.Success);
                    await RefreshDataAsync();
                    StateHasChanged();
                });
            });

            hubConnection.On<MacroSutra.Core.Models.PortfolioUpdateEvent>("PortfolioUpdated", async _ =>
            {
                await InvokeAsync(async () =>
                {
                    await RefreshDataAsync();
                    StateHasChanged();
                });
            });

            await hubConnection.StartAsync();
            await hubConnection.InvokeAsync("JoinAccount", AccountId);
        }
        catch { /* SignalR not available */ }
    }

    public async ValueTask DisposeAsync()
    {
        if (autoRefreshTimer != null) await autoRefreshTimer.DisposeAsync();
        if (hubConnection != null) await hubConnection.DisposeAsync();
    }
}
