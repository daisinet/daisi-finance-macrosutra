@page "/strategies"
@implements IAsyncDisposable
@using Microsoft.AspNetCore.SignalR.Client

<PageTitle>Strategies — MacroSutra</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Strategies</MudText>

<MudStack Row="true" Class="mb-4">
    <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/strategies/new">
        <MudIcon Icon="@Icons.Material.Filled.Add" Class="me-1" /> New Strategy
    </MudButton>
    <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Href="/strategies/templates">
        <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Class="me-1" /> Templates
    </MudButton>
</MudStack>

<MudTable Items="@strategies" Hover="true" Striped="true" Dense="true" Loading="@loading">
    <HeaderContent>
        <MudTh>Name</MudTh>
        <MudTh>Symbols</MudTh>
        <MudTh>Conditions</MudTh>
        <MudTh>Last Evaluated</MudTh>
        <MudTh>Last Triggered</MudTh>
        <MudTh>Active</MudTh>
        <MudTh>Public</MudTh>
        <MudTh>Actions</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>
            @context.Name
            @if (!string.IsNullOrEmpty(context.ForkedFromStrategyId))
            {
                <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Secondary">
                    <i class="fa-duotone fa-code-fork me-1"></i> Forked
                </MudChip>
            }
            @if (recentlyTriggered.Contains(context.id))
            {
                <MudChip T="string" Size="Size.Small" Color="Color.Success">
                    Just Triggered
                </MudChip>
            }
        </MudTd>
        <MudTd>
            @foreach (var sym in context.Symbols)
            {
                <MudChip T="string" Size="Size.Small" Color="Color.Info">@sym</MudChip>
            }
        </MudTd>
        <MudTd>@context.TriggerGroups.Count group(s)</MudTd>
        <MudTd>
            @if (context.LastEvaluatedUtc.HasValue)
            {
                <MudText Typo="Typo.caption">@context.LastEvaluatedUtc.Value.ToString("MMM dd, HH:mm")</MudText>
            }
            else
            {
                <MudText Typo="Typo.caption" Color="Color.Secondary">—</MudText>
            }
        </MudTd>
        <MudTd>
            @if (context.LastTriggeredUtc.HasValue)
            {
                <MudText Typo="Typo.caption">@context.LastTriggeredUtc.Value.ToString("MMM dd, HH:mm")</MudText>
            }
            else
            {
                <MudText Typo="Typo.caption" Color="Color.Secondary">—</MudText>
            }
        </MudTd>
        <MudTd>
            <MudSwitch T="bool" Value="@context.IsActive" ValueChanged="@(v => ToggleActive(context, v))" Color="Color.Success" />
        </MudTd>
        <MudTd>
            <MudIcon Icon="@(context.IsPublic ? Icons.Material.Filled.Public : Icons.Material.Filled.Lock)" />
        </MudTd>
        <MudTd>
            <MudIconButton Icon="@Icons.Material.Filled.PlayArrow" OnClick="@(() => TestNow(context))" Size="Size.Small" Title="Test Now" Color="Color.Info" />
            <MudIconButton Icon="@Icons.Material.Filled.BarChart" Href="@($"/strategies/{context.id}/performance")" Size="Size.Small" Title="Performance" Color="Color.Secondary" />
            <MudIconButton Icon="@Icons.Material.Filled.Edit" Href="@($"/strategies/{context.id}")" Size="Size.Small" />
            <MudIconButton Icon="@Icons.Material.Filled.Delete" OnClick="@(() => DeleteStrategy(context))" Size="Size.Small" Color="Color.Error" />
        </MudTd>
    </RowTemplate>
</MudTable>

@code {
    [CascadingParameter(Name = "AccountId")] private string AccountId { get; set; } = "";
    [Inject] private IDataProvider Data { get; set; } = default!;
    [Inject] private ISnackbar Snackbar { get; set; } = default!;
    [Inject] private NavigationManager Nav { get; set; } = default!;

    private List<TradingStrategy> strategies = new();
    private bool loading = true;
    private HashSet<string> recentlyTriggered = new();
    private HubConnection? hubConnection;

    protected override async Task OnParametersSetAsync()
    {
        if (string.IsNullOrEmpty(AccountId)) return;
        await LoadStrategies();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !string.IsNullOrEmpty(AccountId))
        {
            try
            {
                hubConnection = new HubConnectionBuilder()
                    .WithUrl(Nav.ToAbsoluteUri("/hubs/macrosutra"))
                    .WithAutomaticReconnect()
                    .Build();

                hubConnection.On<MacroSutra.Core.Models.StrategyAlertEvent>("StrategyTriggered", async alert =>
                {
                    await InvokeAsync(async () =>
                    {
                        recentlyTriggered.Add(alert.StrategyId);
                        Snackbar.Add($"{alert.StrategyName} triggered on {alert.Symbol}", Severity.Success);
                        await LoadStrategies();
                        StateHasChanged();
                    });
                });

                await hubConnection.StartAsync();
                await hubConnection.InvokeAsync("JoinAccount", AccountId);
            }
            catch { }
        }
    }

    private async Task LoadStrategies()
    {
        loading = true;
        try { strategies = await Data.GetStrategiesAsync(AccountId); }
        catch { Snackbar.Add("Failed to load strategies.", Severity.Error); }
        finally { loading = false; }
    }

    private async Task ToggleActive(TradingStrategy strategy, bool active)
    {
        try
        {
            if (active)
                await Data.ActivateStrategyAsync(strategy.id, AccountId);
            else
                await Data.DeactivateStrategyAsync(strategy.id, AccountId);
            await LoadStrategies();
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
    }

    private async Task DeleteStrategy(TradingStrategy strategy)
    {
        try
        {
            await Data.DeleteStrategyAsync(strategy.id, AccountId);
            Snackbar.Add("Strategy deleted.", Severity.Success);
            await LoadStrategies();
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
    }

    private async Task TestNow(TradingStrategy strategy)
    {
        try
        {
            var result = await Data.EvaluateStrategyAsync(strategy.id, AccountId);
            var passed = result.Conditions.Count(c => c.Passed);
            var total = result.Conditions.Count;
            var severity = result.WouldTrigger ? Severity.Success : Severity.Info;
            var msg = result.WouldTrigger
                ? $"Would trigger! {passed}/{total} conditions passed."
                : $"Would NOT trigger. {passed}/{total} conditions passed.";
            Snackbar.Add(msg, severity);
        }
        catch (Exception ex) { Snackbar.Add($"Evaluation failed: {ex.Message}", Severity.Error); }
    }

    public async ValueTask DisposeAsync()
    {
        if (hubConnection != null) await hubConnection.DisposeAsync();
    }
}
