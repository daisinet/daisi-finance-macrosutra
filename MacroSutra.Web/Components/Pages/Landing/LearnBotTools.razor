                <tr><td>Strategy</td><td><code>macrosutra-strategy</code></td><td>TradingTools</td></tr>
                <tr><td>Trade</td><td><code>macrosutra-trade</code></td><td>TradingTools</td></tr>
                <tr><td>Performance</td><td><code>macrosutra-performance</code></td><td>TradingTools</td></tr>
                <tr><td>Backtest</td><td><code>macrosutra-backtest</code></td><td>TradingTools</td></tr>
                <tr><td>Strategy Builder</td><td><code>macrosutra-strategy-builder</code></td><td>AITools</td></tr>
                <tr><td>Risk Assessment</td><td><code>macrosutra-risk-assessment</code></td><td>AITools</td></tr>
                <tr><td>Market Sentiment</td><td><code>macrosutra-market-sentiment</code></td><td>AITools</td></tr>
            </tbody>
        </table>
    </div>
</section>
