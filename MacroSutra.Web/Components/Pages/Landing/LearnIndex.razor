@page "/learn"
@layout MacroSutra.Web.Components.Layout.LandingLayout

<PageTitle>MacroSutra - Learn</PageTitle>

<section class="landing-section">
    <div class="landing-container">
        <h1 class="text-center">Learn</h1>
        <p class="text-center landing-hero-subtitle">Guides, references, and tutorials to help you get the most out of MacroSutra.</p>

        <h2>Getting Started</h2>
        <ul class="landing-learn-list">
            <li><a href="/learn/getting-started">Getting Started with MacroSutra</a> — Create your account, link a brokerage, and build your first strategy.</li>
        </ul>

        <h2 class="mt-4">SDK &amp; API</h2>
        <ul class="landing-learn-list">
            <li><a href="/learn/sdk">SDK Reference</a> — Install the .NET SDK, authenticate, and manage strategies, trades, and portfolios programmatically.</li>
        </ul>

        <h2 class="mt-4">Strategies</h2>
        <ul class="landing-learn-list">
            <li><a href="/learn/getting-started#strategies">Building Strategies</a> — Triggers, conditions, and actions explained.</li>
            <li><a href="/learn/conditions">Conditions &amp; Strategy Logic</a> — Complete reference for condition types, operators, actions, quantity types, logic groups, and strategy templates.</li>
            <li><a href="/learn/strategy-builder">Visual Strategy Builder</a> — Drag-and-drop builder, condition wizard, template gallery, and live preview guide.</li>
        </ul>

        <h2 class="mt-4">Backtesting</h2>
        <ul class="landing-learn-list">
            <li><a href="/learn/backtesting">Backtesting &amp; Walk-Forward Analysis</a> — Run backtests, interpret metrics (Sharpe ratio, max drawdown, win rate), validate with walk-forward analysis, and avoid overfitting.</li>
        </ul>

        <h2 class="mt-4">Community</h2>
        <ul class="landing-learn-list">
            <li><a href="/learn/marketplace">Strategy Marketplace</a> — Browse, fork, review, and rank community strategies.</li>
            <li><a href="/learn/getting-started#sharing">Sharing Your Strategies</a> — Make strategies public, manage visibility, and grow your audience.</li>
        </ul>

        <h2 class="mt-4">Portfolio</h2>
        <ul class="landing-learn-list">
            <li><a href="/learn/getting-started#brokerage">Linking Brokerage Accounts</a> — Connect your broker and sync positions.</li>
            <li><a href="/learn/brokerages">Brokerage Integration Guide</a> — Supported brokerages, credential setup, paper trading modes, and provider health monitoring.</li>
            <li><a href="/learn/rebalancing">Portfolio Rebalancing</a> — Set target allocations, detect drift, and execute rebalancing trades.</li>
            <li><a href="/learn/tax-loss-harvesting">Tax-Loss Harvesting</a> — Scan your portfolio for unrealized losses and estimate tax savings.</li>
        </ul>

        <h2 class="mt-4">Advanced Trading</h2>
        <ul class="landing-learn-list">
            <li><a href="/learn/charting">Advanced Charting</a> — Interactive candlestick and line charts powered by TradingView Lightweight Charts.</li>
            <li><a href="/learn/dca">Dollar-Cost Averaging (DCA)</a> — Automate recurring buys with configurable schedules.</li>
            <li><a href="/learn/options">Options Trading (V1)</a> — Buy and sell single-leg options contracts through Alpaca and Tastytrade.</li>
            <li><a href="/learn/export">Trade Export</a> — Export your trade history to CSV or PDF.</li>
        </ul>

        <h2 class="mt-4">Bot Tools &amp; AI</h2>
        <ul class="landing-learn-list">
            <li><a href="/learn/bot-tools">Bot Tools &amp; AI Features</a> — Use Daisinet bots to manage your portfolio, build strategies with natural language, assess risk, and analyze market sentiment.</li>
        </ul>
    </div>
</section>
