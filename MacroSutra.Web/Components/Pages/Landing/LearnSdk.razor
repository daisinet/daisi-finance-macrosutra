@page "/learn/sdk"
@layout MacroSutra.Web.Components.Layout.LandingLayout

<PageTitle>MacroSutra - SDK Reference</PageTitle>

<section class="landing-section">
    <div class="landing-container">
        <h1>SDK Reference</h1>
        <p>The MacroSutra .NET SDK lets you manage strategies, query trades, and access portfolio data programmatically.</p>

        <h2 id="installation" class="mt-4">Installation</h2>
        <p>Install the SDK via NuGet:</p>
<pre><code>dotnet add package Daisi.SDK</code></pre>

        <h2 id="authentication" class="mt-4">Authentication</h2>
        <p>Authenticate with your DAISI client key. You can find your key in the Daisinet Manager under <strong>Account Settings &rarr; API Keys</strong>.</p>
<pre><code>using Daisi.SDK.Models;

DaisiStaticSettings.ClientKey = "your-client-key";
DaisiStaticSettings.OrcIpAddressOrDomain = "orc.daisinet.com";
DaisiStaticSettings.OrcPort = 443;
DaisiStaticSettings.OrcUseSSL = true;</code></pre>

        <h2 id="strategies" class="mt-4">Strategy CRUD</h2>
        <p>Create, read, update, and delete trading strategies:</p>
<pre><code>// Create a new strategy
var strategy = new MacroSutraStrategy
{
    Name = "My Price Alert Strategy",
    Description = "Buy when price drops below threshold",
    IsActive = true,
    Triggers = new List&lt;StrategyTrigger&gt;
    {
        new StrategyTrigger { Type = "PriceBelow", Symbol = "AAPL", Value = 150.00m }
    },
    Conditions = new List&lt;StrategyCondition&gt;
    {
        new StrategyCondition { Type = "MaxPositionSize", Value = 100 }
    },
    Actions = new List&lt;StrategyAction&gt;
    {
        new StrategyAction { Type = "Buy", Symbol = "AAPL", Quantity = 10 }
    }
};

var created = await strategyService.CreateAsync(accountId, strategy);

// List all strategies
var strategies = await strategyService.GetAllAsync(accountId);

// Update a strategy
created.IsActive = false;
await strategyService.UpdateAsync(accountId, created);

// Delete a strategy
await strategyService.DeleteAsync(accountId, created.Id);</code></pre>

        <h2 id="trades" class="mt-4">Trade Queries</h2>
        <p>Query trade history with optional filters:</p>
<pre><code>// Get all trades
var trades = await tradeService.GetTradesAsync(accountId);

// Filter by symbol
var appleTrades = await tradeService.GetTradesAsync(accountId, symbol: "AAPL");

// Filter by strategy
var strategyTrades = await tradeService.GetTradesAsync(accountId, strategyId: myStrategy.Id);</code></pre>

        <h2 id="portfolio" class="mt-4">Portfolio Queries</h2>
        <p>Access positions and brokerage account data:</p>
<pre><code>// Get all positions across brokerages
var positions = await portfolioService.GetPositionsAsync(accountId);

// Get brokerage accounts
var accounts = await portfolioService.GetBrokerageAccountsAsync(accountId);

// Get positions for a specific brokerage account
var accountPositions = await portfolioService.GetPositionsAsync(accountId, brokerageAccountId: account.Id);</code></pre>

        <h2 id="community" class="mt-4">Community Client</h2>
        <p>Browse public strategies, view the leaderboard, fork strategies, and manage reviews:</p>
<pre><code>// Browse public strategies (no auth required)
var publicStrategies = await client.Community.GetPublicStrategiesAsync();

// Get leaderboard sorted by Sharpe ratio
var leaderboard = await client.Community.GetLeaderboardAsync(sortBy: "sharpe", top: 10);

// Fork a public strategy into your account
var forkedStrategy = await client.Community.ForkStrategyAsync("strategy-id");

// Leave a review on a public strategy
var review = await client.Community.CreateReviewAsync("strategy-id",
    new CreateReviewRequest { Rating = 5, Text = "Solid RSI strategy." });

// Update your review
await client.Community.UpdateReviewAsync("strategy-id", "review-id",
    new UpdateReviewRequest { Rating = 4, Text = "Updated review." });

// Delete your review
await client.Community.DeleteReviewAsync("strategy-id", "review-id");

// Get reviews for a strategy
var reviews = await client.Community.GetReviewsAsync("strategy-id");</code></pre>

        <h2 id="subscriptions" class="mt-4">Subscription Client</h2>
        <p>Subscribe to other traders' strategies and manage your subscriptions:</p>
<pre><code>// Subscribe to a strategy with email alerts
var subscription = await client.Subscriptions.SubscribeAsync(
    new CreateSubscriptionRequest
    {
        StrategyId = "strategy-id",
        ActionType = "Email",
        NotificationEmail = "me@example.com"
    });

// Subscribe with trade mirroring
var mirrorSub = await client.Subscriptions.SubscribeAsync(
    new CreateSubscriptionRequest
    {
        StrategyId = "strategy-id",
        ActionType = "Mirror",
        BrokerageAccountId = "account-id"
    });

// Subscribe with scaled mirroring (half the quantity)
var scaledSub = await client.Subscriptions.SubscribeAsync(
    new CreateSubscriptionRequest
    {
        StrategyId = "strategy-id",
        ActionType = "ScaledMirror",
        BrokerageAccountId = "account-id",
        ScaleFactor = 0.5m
    });

// List your active subscriptions
var mySubscriptions = await client.Subscriptions.GetSubscriptionsAsync();

// Get subscribers to your strategies
var mySubscribers = await client.Subscriptions.GetSubscribersAsync();

// Cancel a subscription
await client.Subscriptions.CancelAsync("subscription-id");</code></pre>

        <h2 id="backtest" class="mt-4">Backtest Client</h2>
        <p>Run backtests and retrieve results programmatically:</p>
<pre><code>// Run a new backtest
var result = await client.Backtest.RunAsync(new RunBacktestRequest
{
    StrategyId = "strategy-id",
    Symbol = "AAPL",
    StartDate = new DateOnly(2024, 1, 1),
    EndDate = new DateOnly(2025, 12, 31),
    InitialCapital = 100_000m,
    SlippageBps = 5m,
    CommissionPerTrade = 1.00m
});

// Get a specific backtest result by ID
var backtest = await client.Backtest.GetAsync("backtest-id");

// List all backtests for a strategy
var backtests = await client.Backtest.GetByStrategyAsync("strategy-id");

// List all backtests for your account
var allBacktests = await client.Backtest.GetAllAsync();

// Delete a backtest result
await client.Backtest.DeleteAsync("backtest-id");</code></pre>

        <h2 id="push" class="mt-4">Push Client</h2>
        <p>Manage push notification settings and send notifications:</p>
<pre><code>// Register a device for push notifications
await client.Push.RegisterDeviceAsync(new RegisterDeviceRequest
{
    DeviceToken = "device-token-from-os",
    Platform = "web"  // "web", "ios", or "android"
});

// Send a push notification (typically used by subscription triggers)
await client.Push.SendAsync(new PushNotificationRequest
{
    UserId = "user-id",
    Title = "Strategy Triggered",
    Body = "Your RSI strategy fired a Buy signal for AAPL.",
    Data = new Dictionary&lt;string, string&gt;
    {
        ["strategyId"] = "strategy-id",
        ["symbol"] = "AAPL",
        ["action"] = "Buy"
    }
});

// Unregister a device
await client.Push.UnregisterDeviceAsync("device-token");</code></pre>

        <h2 id="walkforward" class="mt-4">Walk-Forward Client</h2>
        <p>Run walk-forward analysis to validate strategy robustness across rolling time windows:</p>
<pre><code>// Run a walk-forward analysis
var wfResult = await client.WalkForward.RunAsync(new RunWalkForwardRequest
{
    StrategyId = "strategy-id",
    Symbol = "SPY",
    StartDate = new DateOnly(2022, 1, 1),
    EndDate = new DateOnly(2025, 12, 31),
    InitialCapital = 100_000m,
    InSampleMonths = 6,
    OutOfSampleMonths = 2
});

// Access window-level results
foreach (var window in wfResult.Windows)
{
    var label = window.IsInSample ? "IS" : "OOS";
    Console.WriteLine($"{label}: {window.StartDate} - {window.EndDate}, " +
        $"Return: {window.TotalReturnPercent:F2}%, " +
        $"Sharpe: {window.SharpeRatio:F2}");
}

// Access the aggregate summary
var summary = wfResult.Summary;
Console.WriteLine($"Avg OOS Sharpe: {summary.AverageOosSharpe:F2}");
Console.WriteLine($"Avg OOS Return: {summary.AverageOosReturn:F2}%");
Console.WriteLine($"Consistency: {summary.ConsistencyScore:P0}");
Console.WriteLine($"Profitable Windows: {summary.ProfitableOosWindows}/{summary.TotalWindows}");</code></pre>

